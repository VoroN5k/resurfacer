{
  "manifest_version": 3,
  "name": "Resurfacer",
  "version": "0.1.0",
  "description": "Smart Tab Hygiene Assistant — tracks and recaps unfocused tabs.",
  "permissions": [
    "tabs",
    "nativeMessaging",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
