# Rust
/target/
# Cargo.lock is tracked — binary crate, MSVC toolchain, reproducible builds matter

# Runtime artefacts (generated next to the exe)
*.db
*.db-shm
*.db-wal
resurfacer.log
resurfacer-notes.txt

# LLM model weights
models/             # GGUF files are multi-GB; download manually per README

# Native messaging host manifest (filled in by setup.ps1)
# The template is tracked; the generated copy next to the exe is not.
target/**/com.resurfacer.host.json

# Firefox extension — background.js is copied from extension/ by setup.ps1.
# Only manifest.json is tracked; the generated JS is not.
extension-firefox/background.js

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.suo
*.user
*.swp
*~

# Environment / secrets
.env
.env.*
