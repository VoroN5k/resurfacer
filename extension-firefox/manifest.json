{
  "manifest_version": 3,
  "name": "Resurfacer",
  "version": "0.1.0",
  "description": "Smart Tab Hygiene Assistant - tracks and recaps unfocused tabs",
  "permissions": [
    "tabs",
    "nativeMessaging",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "resurfacer@resurfacer.local",
      "strict_min_version": "109.0"
    }
  }
}
